ASYNC_DB_URL=postgresql+asyncpg://user:password@localhost:5432/db_name
ASYNC_TEST_DB_URL=postgresql+asyncpg://user:password@localhost:5432/test_db_name

ARGON2_PASSWORD_PEPPER=your_argon_pepper

ACCESS_TOKEN_SECRET_KEY=your_access_token_secret_key
