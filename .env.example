ACCESS_TOKEN_EXPIRE_TIME=your_access_token_expire_time
REFRESH_TOKEN_EXPIRE_TIME=your_refresh_token_expire_time

REDIS_URL=redis://localhost:6379    # add password if applicable

SENTRY_SDK_DSN=your_sentry_sdk_dsn  # get at https://sentry.io

CLIENT_ID=your_google_oauth_client_id
